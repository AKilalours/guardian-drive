# Guardian Drive — Environment Configuration
# Copy to .env and fill in your values

# Pipeline
GD_LIVE_ONLY=0
GD_ENABLE_WEBCAM=1
GD_WINDOW_SEC=8
GD_STEP_SEC=2
GD_VOICE=1

# Model
GD_TASK_B_MLP_WEIGHTS=learned/models/task_b_tcn.pt

# Discord (optional — auto-fires on ESCALATE)
GD_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE

# Scenario (normal/drowsy/afib/tachycardia/bradycardia/crash_mild/crash_severe)
GD_SCENARIO=normal

# Webcam index (0 = default camera)
GD_WEBCAM_INDEX=0

# Server
GD_HOST=127.0.0.1
GD_PORT=8000
